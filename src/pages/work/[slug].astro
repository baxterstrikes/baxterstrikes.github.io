---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies');
  return studies.map((s) => ({ params: { slug: s.id }, props: { study: s } }));
}

const { study } = Astro.props;
const { Content } = await render(study);
---

<Base title={`${study.data.title} — Lynn Baxter`} description={study.data.description}>
  <article class="container study">
    <a class="back" href="/">← All work</a>
    <header>
      <h1>{study.data.title}</h1>
      <p class="desc">{study.data.description}</p>
    </header>
    {study.data.hero && <img class="hero" src={study.data.hero} alt={study.data.title} />}
    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .study { padding-block: 2.5rem 6rem; }
    .back { font-size: 0.92rem; color: var(--color-muted); text-decoration: none; }
    .back:hover { color: var(--color-clay); }
    header h1 { font-size: var(--step-4); margin: 1.5rem 0 0.4rem; }
    .desc {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 1.35rem;
      color: var(--color-ink-soft);
      margin: 0 0 2rem;
      max-width: 42ch;
    }
    .hero { border-radius: var(--radius); margin: 0 0 1rem; }
    .prose { max-width: 68ch; }
    .prose :global(h2) {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: var(--step-3);
      margin: 3.5rem 0 0.5rem;
    }
    .prose :global(h3) {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: var(--step-1);
      margin: 2.25rem 0 0.4rem;
    }
    .prose :global(p) { margin: 0 0 1rem; }
    .prose :global(img) { border-radius: 10px; margin: 1.25rem 0; }
    .prose :global(em) { color: var(--color-clay); font-style: italic; }
    .prose :global(ul) { padding-left: 1.2rem; }
    .prose :global(li) { margin: 0.4rem 0; }
  </style>
</Base>
