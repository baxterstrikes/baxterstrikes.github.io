---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';
import frauncesUrl from '@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url';
import interUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Lynn Baxter — Designer',
  description = 'A designer who builds calm, intentional things for kids and the people raising them.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={frauncesUrl} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interUrl} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <nav class="site-nav">
      <a class="wordmark" href="/">Lynn Baxter</a>
      <div class="links">
        <a href="/">Work</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      <span>Lynn Baxter — designer · Albany, CA</span>
    </footer>

    <style>
      .site-nav {
        max-width: 760px;
        margin: 0 auto;
        padding: 1.5rem clamp(1.25rem, 4vw, 2rem);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        row-gap: 0.6rem;
        column-gap: 1rem;
      }
      .site-nav .wordmark {
        font-family: var(--font-display);
        font-weight: 500;
        font-size: 1.15rem;
        text-decoration: none;
        letter-spacing: -0.01em;
        color: var(--color-ink);
      }
      .site-nav .links { display: flex; gap: clamp(1rem, 3vw, 1.5rem); }
      .site-nav .links a { font-size: var(--step-0); text-decoration: none; color: var(--color-muted); }
      .site-nav .links a:hover { color: var(--color-clay); }
      .site-footer {
        max-width: 760px;
        margin: 4rem auto 0;
        padding: 1.5rem clamp(1.25rem, 4vw, 2rem) 3rem;
        border-top: 1px solid var(--color-line);
        color: var(--color-faint);
        font-size: var(--step--1);
      }
    </style>

    <script is:inline>
      // Keep raster screenshots crisp: never display an image wider than its own
      // pixels allow at the current device pixel ratio. Low-res shots shrink to a
      // sharp, centered size instead of stretching blurry across the column.
      (function () {
        function fit(img) {
          if (!img.naturalWidth) return;
          var dpr = Math.max(1, window.devicePixelRatio || 1);
          var crisp = Math.round(img.naturalWidth / dpr);
          img.style.maxWidth = 'min(100%, ' + crisp + 'px)';
        }
        function fitAll() {
          document.querySelectorAll('.prose img, img.hero').forEach(function (img) {
            if (img.complete) fit(img);
            else img.addEventListener('load', function () { fit(img); }, { once: true });
          });
        }
        if (document.readyState !== 'loading') fitAll();
        else document.addEventListener('DOMContentLoaded', fitAll);
        var t;
        window.addEventListener('resize', function () {
          clearTimeout(t);
          t = setTimeout(function () {
            document.querySelectorAll('.prose img, img.hero').forEach(fit);
          }, 150);
        });
      })();
    </script>
  </body>
</html>
